---
import classNames from "classnames";
import type { HTMLTag, Polymorphic } from "astro/types";

type Variant = "default" | "outline" | "ghost";
type Size = "sm" | "base" | "lg";

type Props<Tag extends HTMLTag = "button"> = Polymorphic<{ as: Tag }> & {
  variant?: Variant;
  size?: Size;
  square?: boolean;
  round?: boolean;
  asChild?: boolean;
  class?: string;
};

const {
  as: Tag = "button",
  type = "button",
  variant = "default",
  size = "base",
  square = false,
  round = false,
  asChild = false,
  class: className,
  ...rest
} = Astro.props;

const baseClasses =
  "inline-flex items-center justify-center font-accent uppercase focus:outline-none focus:ring-2 focus:ring-accent-500 cursor-pointer";

const variantClasses = classNames({
  "bg-neutral-800 text-neutral-100 hover:bg-neutral-700 active:text-accent-500":
    variant === "default",
  "border-2 border-neutral-800 text-neutral-700 bg-transparent hover:bg-neutral-300 active:text-accent-500 active:border-accent-500":
    variant === "outline",
  "text-neutral-700 bg-transparent hover:bg-neutral-300 active:text-accent-500":
    variant === "ghost",
});

const sizeClasses = classNames({
  "text-sm h-10 px-3.5": size === "sm",
  "text-base h-10.5 px-4": size === "base",
  "text-lg h-11 px-4.5": size === "lg",
});

const shapeClasses = classNames({
  "aspect-square !px-0": square,
  "rounded-full": round,
});

const classes = classNames(baseClasses, variantClasses, sizeClasses, shapeClasses, className);
---

{
  asChild ? (
    <slot />
  ) : (
    <Tag type={type} class={classes} {...rest}>
      <slot />
    </Tag>
  )
}
