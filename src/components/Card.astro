---
import classNames from "classnames";
import Image from "./Image.astro";
import Button from "./Button.astro";
import Tag from "./Tag.astro";
import Header from "./Header.astro";
import Text from "./Text.astro";

interface Props {
  image?: string;
  title: string;
  description: string;
  href: string;
  tags?: string[];
  class?: string;
}

const { image, title, description, href, tags = [], class: className } = Astro.props;
---

<article class={classNames("flex flex-col gap-2", className)}>
  <div class="border-2 border-neutral-800 flex flex-col">
    <Image src={image} alt={title} class="w-full aspect-video" />
    <div class="p-3 flex flex-col gap-2">
      <Header variant="h3" size="sm">{title}</Header>
      <Text as="p" class="line-clamp-4">{description}</Text>
      <Button asChild class="w-full mt-1" aria-label={`Read more about ${title}`}>
        <a href={href}>Read More</a>
      </Button>
    </div>
  </div>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1">
      {tags.map((tag) => (
        <Tag size="sm">{tag}</Tag>
      ))}
    </div>
  )}
</article>
