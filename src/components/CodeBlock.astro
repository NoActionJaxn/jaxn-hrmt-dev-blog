---
import classNames from "classnames";
import Button from "./Button.astro";
import { t } from "../i18n/utils";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div
  class={classNames(
    "relative bg-neutral-800 font-mono text-sm text-neutral-100",
    className,
  )}
  data-codeblock
>
  <Button
    type="button"
    class="absolute top-2 right-2 text-success-500"
    data-codeblock-copy
    aria-label={t("codeblock.copyCode")}
    square
  >
    <i class="fa-solid fa-copy text-lg" aria-hidden="true"></i>
  </Button>
  <span class="sr-only" data-codeblock-status aria-live="polite" data-copied-msg={t("codeblock.copiedToClipboard")}></span>
  <pre class="font-mono p-6 pr-10 overflow-x-auto text-success-500"><code><slot /></code></pre>
</div>

<script>
  function initCodeBlocks() {
    document
      .querySelectorAll<HTMLElement>("[data-codeblock]")
      .forEach((block) => {
        if (block.dataset.codeblockInitialized) return;
        block.dataset.codeblockInitialized = "true";

        const btn = block.querySelector<HTMLButtonElement>(
          "[data-codeblock-copy]",
        )!;
        const code = block.querySelector("code")!;

        btn.addEventListener("click", () => {
          navigator.clipboard.writeText(code.textContent || "");
          const icon = btn.querySelector("i")!;
          const status = block.querySelector<HTMLElement>("[data-codeblock-status]")!;
          icon.classList.replace("fa-copy", "fa-check");
          status.textContent = status.dataset.copiedMsg || "Copied to clipboard";
          setTimeout(() => {
            icon.classList.replace("fa-check", "fa-copy");
            status.textContent = "";
          }, 1500);
        });
      });
  }

  initCodeBlocks();
  document.addEventListener("astro:page-load", initCodeBlocks);
</script>
