---
import classNames from "classnames";
import Button from "./Button.astro";
import Accent from "./Accent.astro";
import Text from "./Text.astro";
import { t } from "../i18n/utils";

interface Props {
  title: string;
  description: string;
  confirmLabel?: string;
  cancelLabel?: string;
  class?: string;
}

const {
  title,
  description,
  confirmLabel = t("dialog.confirm"),
  cancelLabel = t("dialog.cancel"),
  class: className,
} = Astro.props;
const dialogId = `confirm-dialog-${Math.random().toString(36).slice(2, 8)}`;
---

<div
  class={classNames("border-2 border-neutral-800", className)}
  data-confirm-dialog
  role="dialog"
  aria-labelledby={`${dialogId}-title`}
  aria-describedby={`${dialogId}-desc`}
>
  <div class="p-6 flex flex-col gap-2">
    <Accent as="h3" size="sm" id={`${dialogId}-title`}>{title}</Accent>
    <Text as="p" id={`${dialogId}-desc`}>{description}</Text>
    <div class="flex justify-end gap-2 mt-2">
      <Button size="sm" data-confirm-dialog-confirm>{confirmLabel}</Button>
      <Button size="sm" variant="outline" data-confirm-dialog-cancel>{cancelLabel}</Button>
    </div>
  </div>
</div>
