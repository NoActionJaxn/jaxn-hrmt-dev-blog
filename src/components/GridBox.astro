---
import classNames from "classnames";

interface Props {
  columns?: 1 | 2 | 3 | 4 | 5;
  gap?: 0 | 1 | 2 | 3 | 4 | 5 | 6 | 8 | 10 | 12;
  class?: string;
}

const { columns = 3, gap = 4, class: className } = Astro.props;

const gapClasses: Record<number, string> = {
  0: "gap-0",
  1: "gap-1",
  2: "gap-2",
  3: "gap-3",
  4: "gap-4",
  5: "gap-5",
  6: "gap-6",
  8: "gap-8",
  10: "gap-10",
  12: "gap-12",
};

const columnClasses: Record<number, string> = {
  1: "grid-cols-1",
  2: "grid-cols-1 sm:grid-cols-2",
  3: "grid-cols-1 sm:grid-cols-2 md:grid-cols-3",
  4: "grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4",
  5: "grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5",
};
---

<div
  class={classNames("grid", gapClasses[gap], columnClasses[columns], className)}
  data-grid-columns={columns}
>
  <slot />
</div>

<script>
  import { isMenuOpen } from "../stores/menuStore";

  function applyMenuState(open: boolean) {
    document.querySelectorAll<HTMLElement>("[data-grid-columns]").forEach((el) => {
      if (open) {
        el.dataset.menuCollapsed = "true";
        el.classList.remove(
          "sm:grid-cols-2",
          "md:grid-cols-3",
          "lg:grid-cols-4"
        );
        el.classList.add("grid-cols-1");
        el.querySelectorAll<HTMLElement>("[class*='col-span-']").forEach((child) => {
          const match = child.className.match(/col-span-(\d+)/);
          if (match) {
            child.dataset.originalColSpan = match[0];
            child.classList.remove(match[0]);
            child.classList.add("col-span-1");
          }
        });
      } else {
        delete el.dataset.menuCollapsed;
        el.classList.remove("grid-cols-1");
        const cols = Number(el.dataset.gridColumns) || 3;
        if (cols >= 2) el.classList.add("sm:grid-cols-2");
        if (cols >= 3) el.classList.add("md:grid-cols-3");
        if (cols >= 4) el.classList.add("lg:grid-cols-4");
        el.querySelectorAll<HTMLElement>("[data-original-col-span]").forEach((child) => {
          child.classList.remove("col-span-1");
          child.classList.add(child.dataset.originalColSpan!);
          delete child.dataset.originalColSpan;
        });
      }
    });
  }

  isMenuOpen.subscribe(applyMenuState);

  document.addEventListener("astro:page-load", () => {
    applyMenuState(isMenuOpen.get());
  });
</script>
