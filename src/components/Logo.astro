---
let title = "jaxn hrmt";
let fullTitle = "jackson hermitt";
---

<div class="p-4 text-5xl inline-block select-none cursor-pointer" aria-label="jackson hermitt">
  <span
    class="font-accent text-accent-500 relative inline-block whitespace-nowrap"
    style="-webkit-text-stroke: 4px var(--color-accent-900); paint-order: stroke fill;"
    data-text={title}
    data-short={title}
    data-full={fullTitle}
    aria-hidden="true">{title}</span
  >
</div>

<style>
  [data-text]::after {
    content: attr(data-text);
    position: absolute;
    left: 3px;
    top: 3px;
    z-index: -1;
    -webkit-text-stroke: 4px var(--color-accent-900);
    paint-order: stroke fill;
    color: var(--color-accent-900);
  }
</style>

<script>
  const chars = "!@#$%^&*()_+-=[]{}|;:,.<>?/~0123456789";

  interface CursorState {
    cursorPos: number;
  }

  function setText(el: HTMLElement, text: string) {
    el.textContent = text;
    el.dataset.text = text;
  }

  function randomChar(): string {
    return chars[Math.floor(Math.random() * chars.length)];
  }

  function delay(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }

  function getState(el: HTMLElement): CursorState {
    let state = (el as any)._cursorState as CursorState | undefined;
    if (!state) {
      state = { cursorPos: 0 };
      (el as any)._cursorState = state;
    }
    return state;
  }

  function animateCursor(
    el: HTMLElement,
    short: string,
    full: string,
    direction: "forward" | "backward",
  ) {
    // cancel any running animation
    (el as any)._cancelAnim?.();

    const state = getState(el);
    const scrambleCount = 3;
    const charDelay = 50;
    const maxLen = full.length;
    let cancelled = false;

    // store cancel handle for next invocation
    (el as any)._cancelAnim = () => { cancelled = true; };

    const settled: string[] = [...(el.textContent || "")];

    async function forward() {
      while (state.cursorPos < maxLen && !cancelled) {
        const i = state.cursorPos;
        for (let s = 0; s < scrambleCount && !cancelled; s++) {
          if (i >= settled.length) settled.push(randomChar());
          else settled[i] = randomChar();
          setText(el, settled.join(""));
          await delay(charDelay);
        }
        if (cancelled) break;
        if (i >= settled.length) settled.push(full[i]);
        else settled[i] = full[i];
        state.cursorPos = i + 1;
        setText(el, settled.join(""));
      }
      if (!cancelled) setText(el, full);
    }

    async function backward() {
      while (state.cursorPos > 0 && !cancelled) {
        const i = state.cursorPos - 1;
        for (let s = 0; s < scrambleCount && !cancelled; s++) {
          settled[i] = randomChar();
          setText(el, settled.join(""));
          await delay(charDelay);
        }
        if (cancelled) break;
        if (i >= short.length) {
          settled.pop();
        } else {
          settled[i] = short[i];
        }
        state.cursorPos = i;
        setText(el, settled.join(""));
      }
      if (!cancelled) setText(el, short);
    }

    if (direction === "forward") {
      forward();
    } else {
      backward();
    }
  }

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.querySelectorAll<HTMLElement>("[data-short][data-full]").forEach((el) => {
    const short = el.dataset.short!;
    const full = el.dataset.full!;
    const parent = el.closest("div")!;

    if (prefersReducedMotion) {
      parent.addEventListener("mouseenter", () => setText(el, full));
      parent.addEventListener("mouseleave", () => setText(el, short));
    } else {
      parent.addEventListener("mouseenter", () => animateCursor(el, short, full, "forward"));
      parent.addEventListener("mouseleave", () => animateCursor(el, short, full, "backward"));
    }
  });
</script>
