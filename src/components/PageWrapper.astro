---
import Header from "./Header.astro";
import Text from "./Text.astro";
import Button from "./Button.astro";
import Accent from "./Accent.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<main
  id="page-wrapper"
  class="pt-28 px-8 gap-8 min-h-screen flex flex-row transition-all duration-300 ease-in-out"
>
  <aside
    class="fixed left-8 top-28 bottom-0 flex flex-col justify-between py-8 w-18 z-30"
  >
    <div class="w-64 origin-top-left rotate-90 translate-x-18 -space-y-2">
      <Header size="xs" class="select-none">{title}</Header>
      <Text as="span" size="xs" class="select-none">
        {description}
      </Text>
    </div>
    <Button
      class="flex-col gap-2 h-auto py-4 px-0!"
      variant="ghost"
      data-back-to-top
    >
      <i class="fa-solid fa-chevron-up" aria-hidden="true"></i>
      <Accent class="text-neutral-800 text-[10px]">Back to Top</Accent>
    </Button>
  </aside>
  <div class="flex flex-col container mx-auto grow pl-24 pb-12">
    <slot />
  </div>
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    document
      .querySelector("[data-back-to-top]")
      ?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
  });
</script>
