---
import classNames from "classnames";
import Text from "./Text.astro";

interface Props extends Omit<astroHTML.JSX.InputHTMLAttributes, "type"> {
  label?: string;
  class?: string;
}

const { label, class: className, id, ...rest } = Astro.props;

const inputId = id ?? (label ? label.toLowerCase().replace(/\s+/g, "-") : undefined);
---

<label class={classNames("inline-flex items-center gap-2 cursor-pointer group", className)}>
  <span class="relative flex items-center justify-center w-6 h-6 shrink-0">
    <input
      type="radio"
      id={inputId}
      class="peer sr-only"
      {...rest}
    />
    <span class="w-6 h-6 rounded-full border-[2.5px] border-neutral-800 bg-neutral-100 peer-focus-visible:ring-2 peer-focus-visible:ring-accent-500 peer-focus-visible:ring-offset-1" />
    <span class="absolute w-3 h-3 rounded-full bg-neutral-800 scale-0 peer-checked:scale-100" />
  </span>
  {label && (
    <Text as="span" class="select-none">{label}</Text>
  )}
</label>
