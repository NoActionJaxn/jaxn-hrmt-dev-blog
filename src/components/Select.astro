---
import classNames from "classnames";

type Size = "sm" | "base" | "lg";

type Option = {
  value: string;
  label: string;
};

interface Props {
  size?: Size;
  label?: string;
  options: Option[];
  placeholder?: string;
  name?: string;
  class?: string;
}

const {
  size = "base",
  label,
  options,
  placeholder = "Choose...",
  name,
  class: className,
} = Astro.props;

const selectId = label ? label.toLowerCase().replace(/\s+/g, "-") : undefined;

const triggerClasses = classNames(
  "flex w-full items-center justify-between border-2 border-neutral-800 bg-neutral-100 px-3 font-sans text-neutral-800 cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500",
  {
    "h-10 text-sm": size === "sm",
    "h-10.5 text-base": size === "base",
    "h-11 text-lg": size === "lg",
  },
);
---

<div class={classNames("relative", className)} data-select>
  {label && (
    <label for={selectId} class="block font-accent uppercase text-sm text-neutral-700 mb-1">
      {label}
    </label>
  )}
  <input type="hidden" name={name} data-select-value />
  <div class="relative" data-select-wrapper>
    <button
      type="button"
      id={selectId}
      class={triggerClasses}
      data-select-trigger
      aria-expanded="false"
      aria-haspopup="listbox"
    >
      <span data-select-display class="text-neutral-400 truncate">{placeholder}</span>
      <i class="fa-solid fa-chevron-down text-neutral-500 ml-2 shrink-0" data-select-icon />
    </button>
    <ul
      class="absolute left-0 right-0 top-full z-10 hidden max-h-60 overflow-y-auto border-2 border-t-0 border-neutral-800 bg-neutral-100"
      data-select-menu
      role="listbox"
    >
      <li
        class="px-3 py-2 font-sans text-neutral-400 cursor-pointer hover:bg-neutral-200"
        data-select-option
        data-value=""
        role="option"
      >
        {placeholder}
      </li>
      {options.map((opt) => (
        <li
          class="px-3 py-2 font-sans text-neutral-800 cursor-pointer hover:bg-neutral-200"
          data-select-option
          data-value={opt.value}
          role="option"
        >
          {opt.label}
        </li>
      ))}
    </ul>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-select]").forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>("[data-select-trigger]")!;
    const wrapper = root.querySelector<HTMLElement>("[data-select-wrapper]")!;
    const menu = root.querySelector<HTMLUListElement>("[data-select-menu]")!;
    const display = root.querySelector<HTMLSpanElement>("[data-select-display]")!;
    const hiddenInput = root.querySelector<HTMLInputElement>("[data-select-value]")!;
    const icon = root.querySelector<HTMLElement>("[data-select-icon]")!;
    const options = root.querySelectorAll<HTMLLIElement>("[data-select-option]");

    function open() {
      menu.classList.remove("hidden");
      trigger.classList.add("border-b-0");
      wrapper.classList.add("ring-2", "ring-accent-500");
      trigger.setAttribute("aria-expanded", "true");
      icon.classList.add("rotate-180");
    }

    function close() {
      menu.classList.add("hidden");
      trigger.classList.remove("border-b-0");
      wrapper.classList.remove("ring-2", "ring-accent-500");
      trigger.setAttribute("aria-expanded", "false");
      icon.classList.remove("rotate-180");
    }

    trigger.addEventListener("click", () => {
      menu.classList.contains("hidden") ? open() : close();
    });

    const placeholder = display.textContent?.trim() ?? "";

    options.forEach((opt) => {
      opt.addEventListener("click", () => {
        const value = opt.dataset.value ?? "";
        hiddenInput.value = value;
        if (value === "") {
          display.textContent = placeholder;
          display.classList.add("text-neutral-400");
          display.classList.remove("text-neutral-800");
        } else {
          display.textContent = opt.textContent?.trim() ?? "";
          display.classList.remove("text-neutral-400");
          display.classList.add("text-neutral-800");
        }
        close();
      });
    });

    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close();
    });
  });
</script>
