---
import classNames from "classnames";

type Size = "sm" | "base" | "lg";

type Option = {
  value: string;
  label: string;
};

interface Props {
  size?: Size;
  label?: string;
  options: Option[];
  placeholder?: string;
  name?: string;
  required?: boolean;
  default?: string;
  class?: string;
}

const {
  size = "base",
  label,
  options,
  placeholder = "Choose...",
  name,
  required = false,
  default: defaultValue,
  class: className,
} = Astro.props;

const defaultOption = defaultValue ? options.find((o) => o.value === defaultValue) : undefined;

const selectId = label ? label.toLowerCase().replace(/\s+/g, "-") : undefined;
const menuId = selectId ? `${selectId}-listbox` : `select-listbox-${Math.random().toString(36).slice(2, 8)}`;

const triggerClasses = classNames(
  "flex w-full items-center justify-between border-2 border-neutral-800 bg-neutral-100 px-3 font-sans text-neutral-800 cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-500",
  {
    "h-10 text-sm": size === "sm",
    "h-10.5 text-base": size === "base",
    "h-11 text-lg": size === "lg",
  },
);
---

<div class={classNames("relative", className)} data-select>
  {label && (
    <label for={selectId} class="block font-accent uppercase text-sm text-neutral-700 mb-1">
      {label}
    </label>
  )}
  <input type="hidden" name={name} required={required} value={defaultOption?.value ?? ""} data-select-value />
  <div class="relative" data-select-wrapper>
    <button
      type="button"
      id={selectId}
      class={triggerClasses}
      data-select-trigger
      aria-expanded="false"
      aria-haspopup="listbox"
      aria-controls={menuId}
    >
      <span data-select-display class:list={["truncate", defaultOption ? "text-neutral-800" : "text-neutral-400"]}>{defaultOption?.label ?? placeholder}</span>
      <i class="fa-solid fa-chevron-down text-neutral-800 ml-2 shrink-0" data-select-icon aria-hidden="true" />
    </button>
    <ul
      class="absolute left-0 right-0 top-full z-10 hidden max-h-60 overflow-y-auto border-2 border-t-0 border-neutral-800 bg-neutral-100"
      data-select-menu
      id={menuId}
      role="listbox"
    >
      {options.map((opt, i) => (
        <li
          class="px-3 py-2 font-sans text-neutral-800 cursor-pointer hover:bg-neutral-200"
          data-select-option
          data-value={opt.value}
          id={`${menuId}-opt-${i}`}
          role="option"
          aria-selected={opt.value === defaultOption?.value ? "true" : "false"}
        >
          {opt.label}
        </li>
      ))}
    </ul>
  </div>
</div>

<script>
  function initSelects() {
    document.querySelectorAll<HTMLElement>("[data-select]").forEach((root) => {
      if (root.dataset.selectInitialized) return;
      root.dataset.selectInitialized = "true";

      const trigger = root.querySelector<HTMLButtonElement>("[data-select-trigger]")!;
    const wrapper = root.querySelector<HTMLElement>("[data-select-wrapper]")!;
    const menu = root.querySelector<HTMLUListElement>("[data-select-menu]")!;
    const display = root.querySelector<HTMLSpanElement>("[data-select-display]")!;
    const hiddenInput = root.querySelector<HTMLInputElement>("[data-select-value]")!;
    const icon = root.querySelector<HTMLElement>("[data-select-icon]")!;
    const optionEls = Array.from(root.querySelectorAll<HTMLLIElement>("[data-select-option]"));

    let activeIndex = -1;

    function setActiveDescendant(index: number) {
      activeIndex = index;
      if (index >= 0 && optionEls[index]) {
        trigger.setAttribute("aria-activedescendant", optionEls[index].id);
        optionEls.forEach((o, i) => {
          o.classList.toggle("bg-neutral-200", i === index);
        });
        optionEls[index].scrollIntoView({ block: "nearest" });
      } else {
        trigger.removeAttribute("aria-activedescendant");
        optionEls.forEach((o) => o.classList.remove("bg-neutral-200"));
      }
    }

    function open() {
      menu.classList.remove("hidden");
      trigger.classList.add("border-b-0");
      wrapper.classList.add("ring-2", "ring-accent-500");
      trigger.setAttribute("aria-expanded", "true");
      icon.classList.add("rotate-180");
      // Highlight currently selected option
      const selectedIdx = optionEls.findIndex((o) => o.getAttribute("aria-selected") === "true");
      setActiveDescendant(selectedIdx >= 0 ? selectedIdx : 0);
    }

    function close() {
      menu.classList.add("hidden");
      trigger.classList.remove("border-b-0");
      wrapper.classList.remove("ring-2", "ring-accent-500");
      trigger.setAttribute("aria-expanded", "false");
      icon.classList.remove("rotate-180");
      setActiveDescendant(-1);
    }

    function selectOption(opt: HTMLLIElement) {
      const value = opt.dataset.value ?? "";
      hiddenInput.value = value;
      optionEls.forEach((o) => o.setAttribute("aria-selected", "false"));
      opt.setAttribute("aria-selected", "true");

      const placeholder = optionEls[0]?.textContent?.trim() ?? "";
      if (value === "") {
        display.textContent = placeholder;
        display.classList.add("text-neutral-400");
        display.classList.remove("text-neutral-800");
      } else {
        display.textContent = opt.textContent?.trim() ?? "";
        display.classList.remove("text-neutral-400");
        display.classList.add("text-neutral-800");
      }
      hiddenInput.dispatchEvent(new Event("change", { bubbles: true }));
      close();
      trigger.focus();
    }

    trigger.addEventListener("click", () => {
      menu.classList.contains("hidden") ? open() : close();
    });

    trigger.addEventListener("keydown", (e) => {
      const isOpen = trigger.getAttribute("aria-expanded") === "true";

      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          if (!isOpen) {
            open();
          } else {
            setActiveDescendant(Math.min(activeIndex + 1, optionEls.length - 1));
          }
          break;
        case "ArrowUp":
          e.preventDefault();
          if (!isOpen) {
            open();
          } else {
            setActiveDescendant(Math.max(activeIndex - 1, 0));
          }
          break;
        case "Home":
          if (isOpen) {
            e.preventDefault();
            setActiveDescendant(0);
          }
          break;
        case "End":
          if (isOpen) {
            e.preventDefault();
            setActiveDescendant(optionEls.length - 1);
          }
          break;
        case "Enter":
        case " ":
          e.preventDefault();
          if (isOpen && activeIndex >= 0) {
            selectOption(optionEls[activeIndex]);
          } else if (!isOpen) {
            open();
          }
          break;
        case "Escape":
          if (isOpen) {
            e.preventDefault();
            close();
          }
          break;
        case "Tab":
          if (isOpen) close();
          break;
      }
    });

    optionEls.forEach((opt, i) => {
      opt.addEventListener("click", () => selectOption(opt));
      opt.addEventListener("mouseenter", () => setActiveDescendant(i));
    });

    document.addEventListener("click", (e) => {
      if (!root.contains(e.target as Node)) close();
    });

    (root as any).selectByValue = (value: string) => {
      const opt = optionEls.find((o) => o.dataset.value === value);
      if (opt) selectOption(opt);
    };
  });
  }

  initSelects();
  document.addEventListener("astro:page-load", initSelects);
</script>
