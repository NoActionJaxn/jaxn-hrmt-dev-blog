---
import classNames from "classnames";

type Size = "sm" | "base" | "lg";

interface Props extends astroHTML.JSX.TextareaHTMLAttributes {
  size?: Size;
  label?: string;
  class?: string;
}

const { size = "base", label, class: className, id, ...rest } = Astro.props;

const inputId = id ?? (label ? label.toLowerCase().replace(/\s+/g, "-") : undefined);

const hasPrepend = Astro.slots.has("prepend");
const hasAppend = Astro.slots.has("append");

const wrapperClasses = classNames(
  "flex border-2 border-neutral-800 bg-neutral-100 focus-within:ring-2 focus-within:ring-accent-500",
  className,
);

const textareaClasses = classNames(
  "flex-1 min-w-0 bg-transparent font-sans text-neutral-800 placeholder:text-neutral-400 focus:outline-none px-3 py-2 resize-y",
  {
    "text-sm": size === "sm",
    "text-base": size === "base",
    "text-lg": size === "lg",
  },
);

const adornmentClasses = "flex items-start pt-2 text-neutral-500 shrink-0";
---

{label && (
  <label for={inputId} class="block font-accent uppercase text-sm text-neutral-700 mb-1">
    {label}
  </label>
)}
<div class={wrapperClasses}>
  {hasPrepend && (
    <span class={classNames(adornmentClasses, "pl-3")}>
      <slot name="prepend" />
    </span>
  )}
  <textarea id={inputId} class={textareaClasses} {...rest} />
  {hasAppend && (
    <span class={classNames(adornmentClasses, "pr-3")}>
      <slot name="append" />
    </span>
  )}
</div>
