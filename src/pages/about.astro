---
import Layout from "../layouts/Layout.astro";
import GridBox from "../components/GridBox.astro";
import Image from "../components/Image.astro";
import Quote from "../components/Quote.astro";
import Header from "../components/Header.astro";
import Accent from "../components/Accent.astro";
import Text from "../components/Text.astro";
import CollapsibleGroup from "../components/CollapsibleGroup.astro";
import Collapsible from "../components/Collapsible.astro";
import Button from "../components/Button.astro";
import { t } from "../i18n/utils";
---

<Layout pageTitle={t("about.pageTitle")} asideTitle={t("about.asideTitle")}>
  <GridBox columns={2} gap={12}>
    <div>
      <Image class="aspect-4/3" />
    </div>
    <div class="flex flex-col justify-center">
      <Quote>
        {t("about.quote")}
      </Quote>
    </div>
    <div class="space-y-4">
      <div>
        <Header variant="h2" size="lg">{t("about.sectionTitle")}</Header>
        <Accent>{t("about.sectionSubtitle")}</Accent>
      </div>
			<div>
				<Text>
					{t("about.sectionText")}
				</Text>
			</div>
			<Button asChild>
				<a href="">{t("about.downloadResume")}</a>
			</Button>
    </div>
    <div>
			<CollapsibleGroup accordion>
					<Collapsible title={t("about.accordion1Title")} open>
						<p>
							{t("about.accordion1Text")}
						</p>
					</Collapsible>
					<Collapsible title={t("about.accordion2Title")}>
						<p>
							{t("about.accordion2Text")}
						</p>
					</Collapsible>
					<Collapsible title={t("about.accordion3Title")}>
						<p>
							{t("about.accordion3Text")}
						</p>
					</Collapsible>
				</CollapsibleGroup>
		</div>
  </GridBox>
</Layout>
