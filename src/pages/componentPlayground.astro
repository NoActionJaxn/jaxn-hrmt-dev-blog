				faucibus ex sapien vitae pellentesque sem placerat.</Info
			>
			<Text as="p">Run <Code>npm install</Code> to get started.</Text>
		</div>
		<div>
			<Quote>Lorem ipsum dolor sit amet consectetur adipiscing elit. Dolor sit amet consectetur adipiscing elit quisque faucibus.</Quote>
		</div>
		<div class="w-sm space-y-2">
			<TagInput
				label="Skills"
				name="skills"
				options={["JavaScript", "TypeScript", "React", "Astro", "CSS", "Tailwind", "Node.js", "Python", "Rust", "Go"]}
				placeholder="Search skills..."
			/>
		</div>
	</div>
</Layout>
