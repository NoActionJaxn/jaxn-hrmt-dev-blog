---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import GridBox from "../../components/GridBox.astro";
import TagInput from "../../components/TagInput.astro";
import Select from "../../components/Select.astro";
import Card from "../../components/Card.astro";
import Button from "../../components/Button.astro";
import Info from "../../components/Info.astro";
import client from "../../../tina/__generated__/client";
import { t } from "../../i18n/utils";

const res = await client.queries.worksConnection();
const works = res.data.worksConnection.edges?.map((edge) => edge?.node) ?? [];

const allTags = [
	...new Set(
		works.flatMap((w) => w?.tags?.filter((t): t is string => t !== null) ?? []),
	),
];

const tagOptions = allTags.map((tag) => ({
	label: tag.charAt(0).toUpperCase() + tag.slice(1),
	value: tag,
}));
---

<Layout pageTitle={t("works.pageTitle")} asideTitle={t("works.asideTitle")}>
	<div class="px-4 pt-8">
		<Header variant="h2">{t("works.heading")}</Header>
	</div>
	<GridBox columns={5} gap={6} class="p-4">
		<div class="col-span-3">
			<TagInput
				label={t("works.keywordFilter")}
				name="keywords"
				placeholder={t("works.enterTags")}
				options={tagOptions}
			/>
		</div>
		<div class="col-span-1">
			<Select
				label={t("works.orderBy")}
				name="sortOrder"
				default="newest"
				placeholder={t("works.sortBy")}
				options={[
					{ label: t("works.newest"), value: "newest" },
					{ label: t("works.oldest"), value: "oldest" },
				]}
			/>
		</div>
		<div class="flex items-end col-span-1">
			<Button class="w-full" data-reset-filters>{t("works.resetFilters")}</Button>
		</div>
	</GridBox>
	<GridBox columns={3} gap={6} class="px-4 py-8" data-cards-grid>
		{
			works.map((work, i) => {
				const cardTags = work?.tags?.filter((t): t is string => t !== null) ?? [];
				const cardDate = work?.createdAt ?? "";
				return (
					<div data-card-item data-tags={cardTags.join(",")} data-date={cardDate}>
						<Card
							title={work?.title ?? ""}
							description={
								work?.description || work?.metadata?.description || ""
							}
							image={work?.thumbnail ?? undefined}
							loading={i < 9 ? "eager" : "lazy"}
							tags={cardTags}
							href={`/works/${work?.slug || work?._sys.filename}`}
						/>
					</div>
				);
			})
		}
	</GridBox>
	<div class="px-4 hidden" data-empty-state>
		<Info>
			<span class="pt-1 block">{t("works.emptyState")}</span>
		</Info>
	</div>
</Layout>

<script>
	function initFilterSync() {
		const keywordsInput = document.querySelector<HTMLInputElement>('input[name="keywords"]');
		const sortInput = document.querySelector<HTMLInputElement>('input[name="sortOrder"]');
		const grid = document.querySelector<HTMLElement>("[data-cards-grid]");
		const emptyState = document.querySelector<HTMLElement>("[data-empty-state]");

		function applyFilters() {
			if (!grid) return;

			const items = Array.from(grid.querySelectorAll<HTMLElement>("[data-card-item]"));
			const keywords = keywordsInput?.value
				? keywordsInput.value.split(",").map((k) => k.trim().toLowerCase()).filter(Boolean)
				: [];
			const sort = sortInput?.value || "newest";

			// Filter
			items.forEach((item) => {
				if (keywords.length === 0) {
					item.style.display = "";
					return;
				}
				const itemTags = (item.dataset.tags || "").split(",").map((t) => t.trim().toLowerCase()).filter(Boolean);
				const matches = keywords.every((kw) => itemTags.includes(kw));
				item.style.display = matches ? "" : "none";
			});

			// Sort
			const sorted = [...items].sort((a, b) => {
				const dateA = new Date(a.dataset.date || 0).getTime();
				const dateB = new Date(b.dataset.date || 0).getTime();
				return sort === "oldest" ? dateA - dateB : dateB - dateA;
			});

			sorted.forEach((item) => grid.appendChild(item));

			const visibleCount = items.filter((item) => item.style.display !== "none").length;
			if (emptyState) {
				emptyState.classList.toggle("hidden", visibleCount > 0);
			}
		}

		function updateParams() {
			const url = new URL(window.location.href);
			const keywords = keywordsInput?.value;
			const sort = sortInput?.value;

			if (keywords) {
				url.searchParams.set("keywords", keywords);
			} else {
				url.searchParams.delete("keywords");
			}

			if (sort && sort !== "newest") {
				url.searchParams.set("sort", sort);
			} else {
				url.searchParams.delete("sort");
			}

			window.history.replaceState({}, "", url);
			applyFilters();
		}

		keywordsInput?.addEventListener("change", updateParams);
		sortInput?.addEventListener("change", updateParams);

		// Reset filters
		const resetBtn = document.querySelector<HTMLButtonElement>("[data-reset-filters]");
		resetBtn?.addEventListener("click", () => {
			const tagInputRoot = document.querySelector<HTMLElement>("[data-tag-input]");
			const tagClearBtn = tagInputRoot?.querySelector<HTMLButtonElement>("[data-tag-clear]");
			tagClearBtn?.click();

			const selectRoot = document.querySelector<HTMLElement>("[data-select]");
			(selectRoot as HTMLElement & { selectByValue?: (value: string) => void })?.selectByValue?.("newest");

			const url = new URL(window.location.href);
			url.searchParams.delete("keywords");
			url.searchParams.delete("sort");
			window.history.replaceState({}, "", url);
			applyFilters();
		});

		// Apply URL params on load
		const url = new URL(window.location.href);
		const initialKeywords = url.searchParams.get("keywords");
		const initialSort = url.searchParams.get("sort");

		if (initialKeywords) {
			const tagInputRoot = document.querySelector<HTMLElement>("[data-tag-input]");
			initialKeywords.split(",").forEach((value) => {
				(tagInputRoot as HTMLElement & { tagInputAddTag?: (value: string) => void })?.tagInputAddTag?.(value);
			});
		}

		if (initialSort) {
			const selectRoot = document.querySelector<HTMLElement>("[data-select]");
			(selectRoot as HTMLElement & { selectByValue?: (value: string) => void })?.selectByValue?.(initialSort);
		}

		applyFilters();
	}

	initFilterSync();
	document.addEventListener("astro:page-load", initFilterSync);
</script>
